{
  "name": "statewrightgate",
  "title": "Statewright Transition Gate",
  "description": "A paid remote MCP for Statewright, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://statewrightgate.clauxel.com/",
  "documentationUrl": "https://statewrightgate.clauxel.com/mcp/",
  "endpointUrl": "https://statewrightgate.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://statewrightgate.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://statewrightgate.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://statewrightgate.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "starter",
        "name": "Starter",
        "monthlyUsd": 29
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 99
      },
      {
        "id": "process",
        "name": "Process",
        "monthlyUsd": 349
      }
    ]
  },
  "tools": [
    {
      "name": "check_state_transition",
      "description": "Statewright Transition Gate check state transition",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sample": {
            "type": "string",
            "description": "Workflow sample, schema, policy fixture, or agent output."
          },
          "context": {
            "type": "string",
            "description": "Optional review context."
          }
        },
        "required": [
          "sample"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "receipt_id": {
            "type": "string"
          },
          "usage_units": {
            "type": "integer"
          },
          "next_action": {
            "type": "string"
          }
        }
      }
    },
